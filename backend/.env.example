# MongoDB Atlas connection string, e.g.
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=
MONGO_DB_NAME=reel_reality_check

# Where downloaded videos / extracted audio / frames are stored on disk (Phase 1)
STORAGE_DIR=./storage

# faster-whisper model size: tiny | base | small | medium | large-v3
# "base" is a good speed/accuracy tradeoff on CPU for Phase 2
WHISPER_MODEL_SIZE=base

# Google Gemini API key (free tier) — get one at https://aistudio.google.com/apikey
# Used for claim extraction (Phase 2) and later fact-check reasoning (Phase 3)
GEMINI_API_KEY=
